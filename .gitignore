# Python / tooling caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.uv-cache/

# Virtual environments and build outputs
.venv/
venv/
dist/
build/

# Local Codex/app metadata
.agents/
.codex/

# Secrets
.env

# Local archive snapshots (the resume backup is ~130 MB and must stay out of Git history)
deepsearch简历版备份.zip
*.backup.zip

# Runtime databases / vector stores
*.sqlite3
*.db
*.npz
data/memory/
data/uploads/

# Keep source datasets, docs, and selected frozen evidence.
# Ignore ad-hoc report outputs by default.
reports/*
!reports/.gitkeep

# Small examples are safe to keep.
!reports/examples/
!reports/examples/**

# Demo default showcase used by the local Web app.
!reports/showcase/
reports/showcase/*
!reports/showcase/final_check/
!reports/showcase/final_check/**

